{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@smart-collab/shared": ["libs/shared/src"],
      "@smart-collab/shared/*": ["libs/shared/src/*"],
      "@smart-collab/events": ["libs/events/src"],
      "@smart-collab/events/*": ["libs/events/src/*"],
      "@smart-collab/mailer": ["libs/mailer/src"],
      "@smart-collab/mailer/*": ["libs/mailer/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
