generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_POSTGRE")
}

model UserCache {
  id        String   @id                // từ Mongo (Auth)
  email     String   @unique
  firstName String?
  lastName  String?
  avatar    String?
  role      String
  updatedAt DateTime @updatedAt @default(now())

  projects  Project[] @relation("ProjectOwner")
  members   ProjectMember[]
}

model Project {
  id               String          @id @default(uuid())
  name             String
  description      String?
  ownerId          String
  folderPath       String?         
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  color            String?
  background       String?
  publicId         String?
  fileUrl          String?
  fileType         String?
  fileSize         Int?
  resourceType     String?
  originalFilename String?
  uploadedById     String?
  visibility       String         @default("private")

  owner       UserCache       @relation("ProjectOwner", fields: [ownerId], references: [id])
  members     ProjectMember[]
  
  @@index([ownerId])
  @@index([uploadedById])
  @@unique([folderPath], map: "unique_project_folderPath")
}


model ProjectMember {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  role      String   @default("MEMBER")

  project   Project   @relation(fields: [projectId], references: [id])
  user      UserCache @relation(fields: [userId], references: [id])
   
  @@unique([projectId, userId])
}
