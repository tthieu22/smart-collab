generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/project-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_POSTGRE")
}

// ------------------ PROJECT ------------------
model Project {
  id          String  @id @default(uuid())
  name        String
  description String?
  ownerId     String
  folderPath  String?
  visibility  String  @default("PRIVATE")
  color       String?
  background  String?

  // File info
  publicId         String?
  fileUrl          String?
  fileType         String?
  fileSize         Int?
  resourceType     String?
  originalFilename String?
  uploadedById     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Recycle Bin & Health
  deletedAt    DateTime?
  isArchived   Boolean   @default(false)
  healthStatus String    @default("ON_TRACK") // ON_TRACK, AT_RISK, DELAYED

  members ProjectMember[]
  boards  Board[]
  columns Column[]
  cards   Card[]
  views   CardView[]
  events  EventStatistic[]

  customFields CustomFieldDefinition[]
  automations  AutomationRule[]
  chatMessages ProjectChatMessage[]

  @@unique([folderPath], map: "unique_project_folderPath")
  @@index([ownerId])
  @@index([uploadedById])
}

// ------------------ PROJECT MEMBER ------------------
model ProjectMember {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  role      String   @default("MEMBER")
  status    String   @default("ACCEPTED") // PENDING, ACCEPTED, REJECTED
  joinedAt  DateTime @default(now())

  // Denormalized user info
  userName    String?
  userAvatar  String?
  userEmail   String?

  // Gamification
  points   Int      @default(0)
  badges   String[] @default([])

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
}

// ------------------ BOARD ------------------
model Board {
  id        String   @id @default(uuid())
  projectId String?
  title     String
  type      String
  position  Int       @default(0)
  columnIds String[]  @default([])
  metadata  Json?

  // Recycle Bin
  deletedAt  DateTime?
  isArchived Boolean   @default(false)

  project   Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columns   Column[]
  ownerId   String?

  @@index([projectId])
  @@index([ownerId])
  @@index([projectId, position])
}

// ------------------ COLUMN ------------------
model Column {
  id        String   @id @default(uuid())
  projectId String?
  boardId   String?
  title     String
  position  Int      @default(0)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Recycle Bin
  deletedAt  DateTime?
  isArchived Boolean   @default(false)

  project Project?    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  board   Board?      @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards   Card[]
  views   CardView[]

  @@index([projectId, boardId, position])
}

// ------------------ CARD ------------------
// ------------------ CARD ------------------
model Card {
  id           String   @id @default(uuid())
  projectId    String?
  columnId     String?
  title        String
  description  String?
  status       String   @default("ACTIVE")
  startDate    DateTime?
  deadline     DateTime?
  priority     Int?
  position     Int      @default(0)

  // Người tạo / sửa (denormalized - không FK)
  createdById     String?
  createdByName   String?
  createdByAvatar String?
  updatedById     String?
  updatedByName   String?
  updatedByAvatar String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Recycle Bin
  deletedAt  DateTime?
  isArchived Boolean   @default(false)
  
  // === COVER IMAGE (ảnh bìa) ===
  coverPublicId     String?
  coverUrl          String?
  coverFileType     String?
  coverFileSize     Int?
  coverResourceType String?
  coverFilename     String?

  // === LOCATION (cho Map View) ===
  locationName      String?
  latitude          Float?
  longitude         Float?

  // === RELATIONS ===
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  column  Column?  @relation(fields: [columnId], references: [id], onDelete: SetNull)

  labels      CardLabel[]
  members     CardMember[]
  views       CardView[]
  comments    CardComment[]
  checklist   ChecklistItem[]
  attachments Attachment[]
  customFieldValues CustomFieldValue[]

  // Gantt Dependencies
  dependencyId String?
  dependency   Card?   @relation("CardDependency", fields: [dependencyId], references: [id], onDelete: SetNull)
  dependents   Card[]  @relation("CardDependency")

  @@index([projectId, status, updatedAt])
  @@index([columnId, position])
}

// ------------------ CARD MEMBER ------------------
model CardMember {
  id          String   @id @default(uuid())
  cardId      String
  userId      String
  userName    String?
  userAvatar  String?
  joinedAt    DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([cardId, userId])
  @@index([userId])
}

// ------------------ CARD COMMENT ------------------
model CardComment {
  id        String   @id @default(uuid())
  cardId    String
  userId    String
  userName  String
  avatar    String?
  content   String
  createdAt DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId, createdAt])
}

// ------------------ CHECKLIST ITEM ------------------
model ChecklistItem {
  id       String @id @default(uuid())
  cardId   String
  title    String
  done     Boolean @default(false)
  position Int     @default(0)

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId, position])
}

// ------------------ ATTACHMENT (File / Image) ------------------
model Attachment {
  id           String   @id @default(uuid())
  cardId       String
  name         String
  url          String
  size         String
  uploadedAt   DateTime @default(now())

  // Người upload (denormalized)
  uploadedById     String?
  uploadedByName   String?
  uploadedByAvatar String?

  // File info (giống Project)
  publicId         String?
  fileType         String?
  fileSize         Int?
  resourceType     String?
  originalFilename String?

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([uploadedAt])
}
// ------------------ CARD LABEL ------------------
model CardLabel {
  id     String @id @default(uuid())
  cardId String
  label  String
  color  String?

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId, label])
}

// ------------------ CARD VIEW ------------------
model CardView {
  id            String   @id @default(uuid())
  cardId        String
  projectId     String
  componentType String // board / inbox / calendar
  columnId      String?
  position      Int      @default(0)
  version       Int      @default(1)
  isPinned      Boolean?
  customTitle   String?
  metadata      Json?
  updatedAt     DateTime @default(now()) @updatedAt

  card    Card    @relation(fields: [cardId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  column  Column? @relation(fields: [columnId], references: [id], onDelete: Cascade)

  @@unique([cardId, projectId, componentType, version], map: "unique_card_view_version")
  @@index([projectId, componentType, position])
  @@index([projectId, columnId, position])
  @@index([cardId])
}

// ------------------ EVENTS / STATISTICS ------------------
model EventStatistic {
  id        String   @id @default(uuid())
  projectId String
  eventType String
  count     Int      @default(0)
  date      DateTime

  project Project @relation(fields: [projectId], references: [id])

  @@unique([projectId, eventType, date])
}

// ------------------ CUSTOM FIELDS ------------------
model CustomFieldDefinition {
  id        String   @id @default(uuid())
  projectId String
  name      String
  type      String   // TEXT, NUMBER, DROPDOWN, DATE
  options   Json?    // For DROPDOWN type
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  values  CustomFieldValue[]

  @@index([projectId])
}

model CustomFieldValue {
  id        String  @id @default(uuid())
  cardId    String
  fieldId   String
  value     String?

  card  Card                  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  field CustomFieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([cardId, fieldId])
  @@index([fieldId])
}

// ------------------ AUTOMATION ------------------
model AutomationRule {
  id           String   @id @default(uuid())
  projectId    String
  name         String
  triggerType  String   // CARD_CREATED, CARD_MOVED, DEADLINE_APPROACHING
  conditions   Json?    // Filter conditions
  actionType   String   // ASSIGN_USER, ADD_LABEL, SEND_NOTIFICATION
  actionConfig Json?    // Action parameters
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ------------------ PROJECT CHAT ------------------
model ProjectChatMessage {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  userName  String?
  avatar    String?
  content   String
  type      String   @default("TEXT") // TEXT, SYSTEM
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}
